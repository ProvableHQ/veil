{
  "compilerOptions": {
    "strict": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noUncheckedIndexedAccess": true,
    "paths": {
      "@provablehq/veil-core": ["./packages/core/src/index.ts"],
      "@provablehq/veil-core/agent": ["./packages/core/src/agent/index.ts"],
      "@provablehq/veil-core/mcp": ["./packages/core/src/mcp/index.ts"],
      "@provablehq/veil-wallet-adapter": ["./packages/wallet-adapter/src/index.ts"],
      "@provablehq/veil-sdk": ["./packages/provable-sdk/src/index.ts"],
      "@provablehq/veil-leo": ["./packages/leo/src/index.ts"],
      "@provablehq/veil-devnode": ["./packages/devnode/src/index.ts"],
      "@provablehq/veil-shield-swap": ["./packages/shield-swap/src/index.ts"],
      "@provablehq/veil-shield-swap/agent": ["./packages/shield-swap/src/agent/index.ts"],
      "@provablehq/veil-shield-swap/mcp": ["./packages/shield-swap/src/mcp/index.ts"],
      "@provablehq/veil-bridge": ["./packages/bridge/src/index.ts"],
      "@provablehq/veil-bridge/agent": ["./packages/bridge/src/agent/index.ts"],
      "@provablehq/veil-bridge/mcp": ["./packages/bridge/src/mcp/index.ts"]
    },
    "types": ["node"]
  },
  "exclude": ["node_modules", "site", "apps"]
}
