{
  "name": "@provablehq/veil-loyalty-node",
  "private": true,
  "type": "module",
  "scripts": {
    "generate": "veil-codegen --abi loyalty_token/build/abi.json --out src/generated/loyalty_token.ts && veil-codegen --abi loyalty_rewards/build/abi.json --out src/generated/loyalty_rewards.ts",
    "start": "tsx src/index.ts",
    "local": "tsx src/index.ts local",
    "delegated": "tsx src/index.ts delegated",
    "start:mint": "tsx src/index.ts mint_card",
    "start:add": "tsx src/index.ts add_points",
    "start:redeem": "tsx src/index.ts redeem_for_voucher"
  },
  "dependencies": {
    "@provablehq/veil-codegen": "workspace:*",
    "@provablehq/veil-core": "workspace:*",
    "@provablehq/veil-sdk": "workspace:*",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "tsx": "^4.21.0",
    "typescript": "^5.7.0"
  }
}
