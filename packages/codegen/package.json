{
  "name": "@veil/codegen",
  "version": "0.4.0",
  "description": "Generate TypeScript types from Aleo program ABIs",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ProvableHQ/veil.git",
    "directory": "packages/codegen"
  },
  "homepage": "https://github.com/ProvableHQ/veil#readme",
  "type": "module",
  "bin": {
    "veil-codegen": "./dist/cli.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "vitest run"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@veil/core": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.7.0"
  }
}
