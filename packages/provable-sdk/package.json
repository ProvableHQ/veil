{
  "name": "@provablehq/veil-aleo-sdk",
  "version": "0.4.1",
  "description": "Local signing and proving for the Veil Aleo SDK, backed by the Provable SDK.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ProvableHQ/veil.git",
    "directory": "packages/provable-sdk"
  },
  "homepage": "https://github.com/ProvableHQ/veil#readme",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@provablehq/veil-core": "workspace:*",
    "@provablehq/veil-aleo-devnode": "workspace:*"
  },
  "dependencies": {
    "@noble/hashes": "^1.7.2",
    "@provablehq/sdk": "^0.11.3",
    "@scure/bip39": "^1.4.0"
  },
  "devDependencies": {
    "@provablehq/veil-leo": "workspace:*"
  }
}
