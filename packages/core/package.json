{
  "name": "@provablehq/veil-core",
  "version": "0.4.0",
  "description": "Core Veil SDK for Aleo — viem-shaped actions, clients, and transports.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ProvableHQ/veil.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/ProvableHQ/veil#readme",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./agent": {
      "types": "./dist/agent/index.d.ts",
      "import": "./dist/agent/index.js"
    },
    "./mcp": {
      "types": "./dist/mcp/index.d.ts",
      "import": "./dist/mcp/index.js"
    }
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@provablehq/aleo-types": "1.0.0"
  }
}
