    call.dynamic r1 'aleo' 'transfer_public' with r5 r4 (as address.public u128.public) into r7 (as dynamic.future);
    async claim_swap_output r6 r7 r0 r1 r2 r3 r4 r5 self.caller into r8;
    output r8 as shield_swap_v0_0_1.aleo/claim_swap_output.future;

finalize claim_swap_output:
    input r0 as dynamic.future;
    input r1 as dynamic.future;
    input r2 as field.public;
    input r3 as field.public;
    input r4 as field.public;
    input r5 as u128.public;
    input r6 as u128.public;
    input r7 as address.public;
    input r8 as address.public;
    await r0;
    await r1;
    get swap_outputs[r2] into r9;
    is.eq r9.caller r8 into r10;
    assert.eq r10 true;
    is.eq r9.recipient r7 into r11;
    assert.eq r11 true;
    is.eq r9.token_in r3 into r12;
    assert.eq r12 true;
    is.eq r9.token_out r4 into r13;
    assert.eq r13 true;
    is.eq r9.amount_out r5 into r14;
    assert.eq r14 true;
    is.eq r9.amount_remaining r6 into r15;
    assert.eq r15 true;
    is.eq r9.amount_remaining_1 0u128 into r16;
    assert.eq r16 true;
    is.eq r9.amount_remaining_2 0u128 into r17;
    assert.eq r17 true;
    remove swap_outputs[r2];

