    input r1 as field.public;
    input r2 as u16.public;
    input r3 as u128.public;
    input r4 as u32.public;
    input r5 as i32.public;
    input r6 as u128.public;
    input r7 as u128.public;
    get token_decimals[r0] into r8;
    get token_decimals[r1] into r9;
    lt r0 r1 into r10;
    ternary r10 r0 r1 into r11;
    ternary r10 r1 r0 into r12;
    lt r0 r1 into r13;
    ternary r13 r8 r9 into r14;
    ternary r13 r9 r8 into r15;
    gt r14 9u8 into r16;
    ternary r16 r14 9u8 into r17;
