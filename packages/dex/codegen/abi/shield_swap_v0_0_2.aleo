    assert.neq r1 shield_swap_v0_0_2.aleo;
    is.eq self.caller self.signer into r5;
    assert.eq r5 true;
    cast r2 r1 r0 into r6 as TokenIDPreimage;
    hash.bhp256 r6 into r7 as field;
    cast r1 r7 r3 r4 r2.pool r2.tick_lower r2.tick_upper into r8 as PositionNFT.record;
    call.dynamic r3 'aleo' 'transfer_public_as_signer' with shield_swap_v0_0_2.aleo r2.amount0_desired (as address.public u128.public) into r9 (as dynamic.future);
    call.dynamic r4 'aleo' 'transfer_public_as_signer' with shield_swap_v0_0_2.aleo r2.amount1_desired (as address.public u128.public) into r10 (as dynamic.future);
    async mint r9 r10 r2 r7 r3 r4 into r11;
    output r7 as field.public;
    output self.signer as address.public;
    output r8 as PositionNFT.record;
    output r11 as shield_swap_v0_0_2.aleo/mint.future;

