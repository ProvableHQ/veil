{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "outDir": "dist",
    "rootDir": "..",
    "paths": {
      "@provablehq/veil-core": ["../core/src"],
      "@provablehq/veil-aleo-wallet-adapter": ["../wallet-adapter/src"]
    }
  },
  "include": ["src"]
}
