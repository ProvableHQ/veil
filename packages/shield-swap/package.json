{
  "name": "@veil/shield-swap",
  "version": "0.4.0",
  "description": "Veil client for the Shield Swap AMM DEX on Aleo.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ProvableHQ/veil.git",
    "directory": "packages/shield-swap"
  },
  "homepage": "https://github.com/ProvableHQ/veil#readme",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./agent": {
      "import": "./dist/agent/index.js",
      "types": "./dist/agent/index.d.ts"
    },
    "./mcp": {
      "import": "./dist/mcp/index.js",
      "types": "./dist/mcp/index.d.ts"
    }
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "generate": "veil-codegen --config codegen/veil.config.json",
    "regen-abi": "./codegen/regen-abi.sh",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "regen-openapi": "./codegen/regen-openapi.sh"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@provablehq/sdk": "^0.11.3"
  },
  "peerDependenciesMeta": {
    "@provablehq/sdk": {
      "optional": true
    }
  },
  "dependencies": {
    "@veil/core": "workspace:*"
  },
  "devDependencies": {
    "@provablehq/sdk": "^0.11.3",
    "@veil/codegen": "workspace:*",
    "@veil/provable-sdk": "workspace:*",
    "openapi-typescript": "^7.13.0"
  }
}
